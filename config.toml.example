# ── HuggingFace Snapshots (full repo, for Diffusers-format models) ──

# [models.some-diffusers-model]
# source = "huggingface_snapshot"
# repo_id = "some/diffusers-model"
# target_dir = "/root/comfy/ComfyUI/models/diffusers/some-model"

# ── Plugins (ComfyUI custom nodes from registry) ──

