# ComfyUI Model & Plugin Configuration
#
# Copy this file to config.toml and edit:
#   cp config.toml.example config.toml
#
# source types:
#   "huggingface"          — single file from HF repo (hf_hub_download)
#   "huggingface_snapshot" — full repo clone (snapshot_download)
#   "external"             — direct URL download (wget), supports CivitAI
#
# model_dir is relative to /root/comfy/ComfyUI/models/
# valid dirs: checkpoints, clip, clip_vision, controlnet, diffusers,
#   embeddings, gligen, hypernetworks, loras, photomaker, style_models,
#   unet, upscale_models, vae, vae_approx

# ── Standalone Models ──

# [models.illustrious-xl]
# source = "huggingface"
# repo_id = "OnomaAIResearch/Illustrious-xl-early-release-v0"
# filename = "Illustrious-XL-v0.1.safetensors"
# model_dir = "checkpoints"

